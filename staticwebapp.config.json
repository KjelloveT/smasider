{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif}", "/css/*"]
  },
  "routes": [
    {
      "route": "/gangespill/*",
      "serve": "/gangespill/index.html"
    },
    {
      "route": "/fotocollage/*", 
      "serve": "/fotocollage/fotocollage.html"
    },
    {
      "route": "/mattespill/*",
      "serve": "/mattespill/index.html"
    },
    {
      "route": "/fotocolours/*",
      "serve": "/fotocolours/index.html"
    },
    {
      "route": "/rundash/*",
      "serve": "/rundash/index.html"
    }
  ]
}
