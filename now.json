{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/gangespell/(.*)",
      "dest": "/gangespell/index.html"
    },
    {
      "src": "/fotocollage/(.*)",
      "dest": "/fotocollage/fotocollage.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
